# Application environment variables (example)
SPRING_PROFILES_ACTIVE=dev
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/orders
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# JWT
APP_JWT_ISSUER=your-issuer
APP_JWT_SECRET=change-me-to-very-long-secret
APP_JWT_ACCESS_TOKEN_TTL_SECONDS=3600

# AWS (used by CI/CD workflows, keep secrets in GitHub Secrets)
AWS_REGION=ap-northeast-2
AWS_ACCOUNT_ID=123456789012
ECR_REPOSITORY=order-service

# Terraform
TF_VAR_environment=dev

